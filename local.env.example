# mutav-stellar — DISPOSABLE TESTNET WALLETS — DO NOT COMMIT
#
# Copy to `local.env` and fill in values. `local.env` is gitignored.
#
# !!! TESTING USE ONLY !!!
#   - Stellar testnet only. Do NOT fund any of these keys on mainnet.
#   - Do NOT reuse for production, real value, or any user-facing flow.
#   - If these secrets ever leak, treat them as compromised: generate fresh
#     keys, sweep balances, redeploy.
#
# Generate keypairs with:  stellar keys generate <name> --network testnet

STELLAR_NETWORK=testnet

# ── Authorized roles ────────────────────────────────────────────────────────
# ADMIN: cold wallet, governance only. On mainnet → hardware wallet on apps/admin.
ADMIN_PUBLIC=
ADMIN_SECRET=

# OPERATOR: daily ops (receive_payment, process_redemptions, add_yield, …).
# On mainnet → KMS-backed Convex Action on mutav-app.
OPERATOR_PUBLIC=
OPERATOR_SECRET=

# TREASURY: protocol_addr — receives protocol-fee share + cover_default destination.
TREASURY_PUBLIC=
TREASURY_SECRET=

# CLASSIC_WALLET: holds USDC on classic Stellar before off-chain TESOURO conversion.
CLASSIC_WALLET_PUBLIC=
CLASSIC_WALLET_SECRET=

# ── Underlying asset ────────────────────────────────────────────────────────
# USDC SEP-41 Stellar Asset Contract.
# To wrap classic USDC on testnet (Circle's testnet issuer):
#   stellar contract asset deploy \
#     --asset USDC:GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5 \
#     --source-account "$ADMIN_SECRET" \
#     --rpc-url https://soroban-testnet.stellar.org \
#     --network-passphrase "Test SDF Network ; September 2015"
USDC_TOKEN=

# ── Investor playground keys (used by #71 investor CLIs + walkthrough) ──────
ALICE_PUBLIC=
ALICE_SECRET=
BOB_PUBLIC=
BOB_SECRET=

# ── Init params (defaults match target architecture — tune as needed) ───────
EXIT_CAP_BPS=1000               # 10% of AUM per weekly cycle
MGMT_FEE_BPS=100                # 1% annual management fee
REDEMPTION_FEE_BPS=25           # 0.25% on each payout
PROTOCOL_FEE_BPS=2000           # 20% of receive_payment routed to treasury
FULFILL_WINDOW_SECONDS=604800   # 7 days before investor can reclaim_expired_redemption
MAX_AUM_INCREASE_BPS=500        # 5% per-call cap on add_yield / add_tenant_fee
TOKEN_NAME=MUTAV Fund
TOKEN_SYMBOL=MTV
