#!/bin/sh
#
# Prevents direct pushes to main. Use a feature branch + PR instead.
#
# Setup (run once after cloning):
#   git config core.hooksPath .githooks

protected_branch="main"
current_branch=$(git symbolic-ref HEAD 2>/dev/null | sed 's|refs/heads/||')

while read local_ref local_sha remote_ref remote_sha; do
  if echo "$remote_ref" | grep -q "refs/heads/${protected_branch}$"; then
    echo ""
    echo "  BLOCKED: Direct push to '${protected_branch}' is not allowed."
    echo ""
    echo "  Use a feature branch instead:"
    echo "    git checkout -b feat/your-feature"
    echo "    git push -u origin feat/your-feature"
    echo "    gh pr create"
    echo ""
    exit 1
  fi
done

exit 0
