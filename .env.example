# Rede Stellar: testnet (padrão) ou mainnet
STELLAR_NETWORK=testnet

# Chave privada do Operador (hot wallet) — nunca commitar o valor real
OPERATOR_SECRET=

# Endereço do contrato MUTAV Fund deployado
FUND_CONTRACT_ID=

# Emissor do USDC na Stellar (diferente em testnet e mainnet)
USDC_ISSUER=

# Contract ID do SAC (Stellar Asset Contract) do USDC — usado para transferências Soroban
USDC_CONTRACT_ID=
